NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

GEMINI_API_KEY=
GEMINI_EXTRACT_MODEL=gemini-1.5-pro
GEMINI_VERIFY_MODEL=gemini-1.5-pro
GEMINI_ADJUDICATE_MODEL=gemini-1.5-pro

DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_EXTRACT_MODEL=qwen-plus
QWEN_VERIFY_MODEL=qwen-plus
QWEN_ADJUDICATE_MODEL=qwen-plus

DATABASE_URL=sqlite:///./data/insurance_news.db
ENABLE_ARTICLE_BODY_FETCH=false
COLLECT_DAYS_BACK=30
MAX_RESULTS_PER_QUERY=200
MAX_COMPANY_ALIASES_FOR_QUERY=3
MAX_QUERIES_PER_COMPANY_PER_MONTH=40
CRAWL_USE_MONTH_KEYWORD=false
CRAWL_MAX_PRODUCT_FOLLOWUP_QUERIES=100
CRAWL_EXTRACTION_MODE=enqueue_only
WEEKLY_UPDATE_EXTRACTION_MODE=enqueue_only
PIVOT_DEFAULT_CONFIDENCE_THRESHOLD=0.65

LLM_PIPELINE_MODE=gemini_extract_qwen_verify
LLM_EXTRACT_ONLY_CANDIDATES=true
LLM_VERIFY_ONLY_RISKY=true
LLM_SKIP_LOW_RELEVANCE=true
LLM_LOW_RELEVANCE_THRESHOLD=0.40
LLM_HIGH_RELEVANCE_THRESHOLD=0.70
LLM_USE_SNIPPETS_ONLY=true
SNIPPET_CONTEXT_SENTENCES=1
MAX_SNIPPET_CHARS_PER_ARTICLE=3000
LLM_MAX_INPUT_CHARS=6000
LLM_MAX_OUTPUT_TOKENS=1200
ENABLE_PRODUCT_CLUSTER_EXTRACTION=true
MAX_ARTICLES_PER_CLUSTER_FOR_LLM=5
MAX_CLUSTER_SNIPPET_CHARS=5000
ENABLE_GEMINI_BATCH=true
BATCH_LLM_FOR_BACKFILL=true
BATCH_LLM_FOR_BLOG=true
GEMINI_BATCH_MODEL=gemini-2.5-flash-lite
LLM_BATCH_MAX_REQUESTS=1000
LLM_BATCH_OUTPUT_DIR=data/llm_batches
ENABLE_GEMINI_GROUNDING=false
EXCLUSIVE_RIGHT_EXTRACTION_DEFAULT_MODE=enqueue_only
EXCLUSIVE_RIGHT_BATCH_DEFAULT=true
EXCLUSIVE_RIGHT_REALTIME_LIMIT=20
EXCLUSIVE_RIGHT_BATCH_LIMIT=1000
EXCLUSIVE_RIGHT_USE_SNIPPETS_ONLY=true
EXCLUSIVE_RIGHT_MAX_SNIPPET_CHARS=3000
EXCLUSIVE_RIGHT_MAX_INPUT_CHARS=5000
GROUNDING_ONLY_ON_CONFLICT=true
PRODUCT_CONSOLIDATION_BATCH_SIZE=100
PRODUCT_CONSOLIDATION_AUTO_AFTER_CRAWL=true
PRODUCT_CONSOLIDATION_AUTO_MODE=rule_only_apply
PRODUCT_CONSOLIDATION_LLM_ENABLED=false
PRODUCT_CONSOLIDATION_LLM_MAX_CALLS_PER_JOB=10
PRODUCT_CONSOLIDATION_LLM_MAX_COST_USD_PER_JOB=1.0
PRODUCT_CONSOLIDATION_LLM_MAX_BLOCK_SIZE=20
PRODUCT_CONSOLIDATION_LLM_MAX_INPUT_CHARS=2500
PRODUCT_CONSOLIDATION_LLM_MAX_OUTPUT_TOKENS=600
PRODUCT_LLM_CONSOLIDATION_ENABLED=false
EXCLUSIVE_RIGHT_LLM_CONSOLIDATION_ENABLED=false
LLM_CONSOLIDATION_PROVIDER=gemini
LLM_CONSOLIDATION_MODEL=gemini-2.5-flash
LLM_CONSOLIDATION_MAX_BLOCK_SIZE=50
LLM_CONSOLIDATION_MAX_CALLS_PER_JOB=20
LLM_CONSOLIDATION_MAX_COST_USD_PER_JOB=2.0
PRODUCT_LLM_CONSOLIDATION_MAX_COMPANIES_PER_JOB=50
PRODUCT_LLM_CONSOLIDATION_MAX_PRODUCTS_PER_PROMPT=60
PRODUCT_LLM_CONSOLIDATION_MAX_CALLS_PER_JOB=30
PRODUCT_LLM_CONSOLIDATION_MAX_COST_USD_PER_JOB=3.0
PRODUCT_LLM_CONSOLIDATION_MODEL=gemini-2.5-flash
EXTRACTION_CONFIDENCE_AUTO_SAVE=0.80
VERIFICATION_CONFIDENCE_AUTO_SAVE=0.80
CONFLICT_REVIEW_THRESHOLD=0.20
ENABLE_PARALLEL_CONSENSUS=false

# Final adjudication is opt-in. Qwen is called only by final-review scripts/API,
# not by crawling, dashboard rendering, search, or Excel export.
ENABLE_FINAL_ADJUDICATION_LLM=false
FINAL_ADJUDICATION_PROVIDER=qwen
QWEN_FINAL_ADJUDICATION_MODEL=qwen-plus

# Scheduled refresh. Use these values on the long-running server process when
# the 09:00 Asia/Seoul refresh should be active.
SCHEDULED_REFRESH_ENABLED=true
SCHEDULED_REFRESH_TIMEZONE=Asia/Seoul
SCHEDULED_REFRESH_DAYS_OF_MONTH=1,6,11,16,21,26,31
SCHEDULED_REFRESH_HOUR=9
SCHEDULED_REFRESH_LOOKBACK_DAYS=5
SCHEDULED_REFRESH_RUN_ON_STARTUP_CATCHUP=false
SCHEDULED_REFRESH_MAX_CONCURRENT_JOBS=1
